# Neon Postgres connection strings (https://neon.tech)
# Direct connection — used by Drizzle Kit for migrations (db:generate / db:migrate).
DATABASE_URL=postgresql://user:password@host/constellation_gallery?sslmode=require

# Pooled connection — used by the serverless runtime (Drizzle client) and the seed script.
DATABASE_URL_POOLED=postgresql://user:password@host/constellation_gallery?sslmode=require&pgbouncer=true

# Secret protecting the /api/cron/sync-database endpoint. Required in production.
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=replace-with-a-long-random-string
